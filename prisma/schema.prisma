generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String    @id @default(cuid())
  name              String?
  email             String    @unique
  emailVerified     DateTime?
  image             String?
  password          String?
  role              String    @default("USER")  // USER | ADMIN
  sessionVersion    Int       @default(0)       // incremented on each login to invalidate old sessions
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  accounts            Account[]
  sessions            Session[]
  resumes             Resume[]
  subscription        Subscription?
  tailorJobs          TailorJob[]
  verificationTokens  VerificationToken[]
  passwordResetTokens PasswordResetToken[]
  usageStats          UsageStats?

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expires   DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expires   DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model Resume {
  id            String   @id @default(cuid())
  userId        String
  title         String
  profileName   String?
  templateId    String   @default("modern-minimal")
  status        String   @default("DRAFT")       // DRAFT | PUBLISHED | ARCHIVED
  isOriginal    Boolean  @default(true)
  parentId      String?
  atsScore      Int?
  atsScoreAfter Int?
  fileUrl       String?
  thumbnailUrl  String?

  personalInfo   String  @default("{}")
  summary        String?
  experience     String  @default("[]")
  education      String  @default("[]")
  skills         String  @default("[]")
  projects       String  @default("[]")
  certifications String  @default("[]")
  languages      String  @default("[]")
  customSections String  @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent     Resume?     @relation("ResumeVersions", fields: [parentId], references: [id])
  versions   Resume[]    @relation("ResumeVersions")
  tailorJobs TailorJob[]
  downloads  Download[]

  @@index([userId])
  @@index([parentId])
}

model TailorJob {
  id               String   @id @default(cuid())
  userId           String
  resumeId         String
  jobTitle         String
  company          String?
  jobDescription   String
  extractedSkills  String   @default("[]")
  missingKeywords  String   @default("[]")
  suggestions      String   @default("[]")
  atsScoreBefore   Int?
  atsScoreAfter    Int?
  keywordMatchPct  Float?
  tailoredResumeId   String?
  coverLetter        String?
  interviewQuestions String   @default("[]")
  atsSimulation      String?
  gapClassification  String?
  status             String   @default("pending")
  applicationStatus  String   @default("SAVED")  // SAVED | APPLIED | PHONE_SCREEN | INTERVIEW | OFFER | REJECTED
  notes              String?
  error              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([resumeId])
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  stripeCustomerId     String    @unique
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  plan                 String    @default("FREE")     // FREE | MONTHLY | YEARLY | LIFETIME
  status               String    @default("TRIALING") // ACTIVE | CANCELED | PAST_DUE | TRIALING | INCOMPLETE
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  trialEnd             DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
}

model UsageStats {
  id             String   @id @default(cuid())
  userId         String   @unique
  resumesCreated Int      @default(0)
  tailorJobsUsed Int      @default(0)
  downloadsCount Int      @default(0)
  monthlyReset   DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Download {
  id        String   @id @default(cuid())
  resumeId  String
  userId    String
  format    String
  fileUrl   String
  createdAt DateTime @default(now())

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId])
  @@index([userId])
}

model Template {
  id         String   @id @default(cuid())
  name       String
  slug       String   @unique
  category   String
  thumbnail  String
  previewUrl String?
  isPremium  Boolean  @default(false)
  isActive   Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model EmailLog {
  id        String   @id @default(cuid())
  to        String
  subject   String
  template  String
  status    String   @default("sent")
  createdAt DateTime @default(now())

  @@index([to])
}
