# ============================================================
# ResumeEvy - Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# ----------------------------
# App
# ----------------------------
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
NEXT_PUBLIC_APP_NAME=ResumeEvy

# ----------------------------
# Database (PostgreSQL - Required for Vercel)
# Recommended: Supabase (free) → https://supabase.com
#              Neon (free)     → https://neon.tech
#
# For Supabase: use the "Transaction" pooler URL for DATABASE_URL
#               and the direct connection URL for DIRECT_URL
# ----------------------------
DATABASE_URL=postgresql://username:password@host:5432/resumeevy?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://username:password@host:5432/resumeevy

# ----------------------------
# NextAuth.js
# Generate secret: openssl rand -base64 32
# ----------------------------
AUTH_SECRET=your-super-secret-key-min-32-chars-long
NEXTAUTH_URL=https://your-app.vercel.app

# ----------------------------
# OAuth Providers
# ----------------------------
# Google OAuth - https://console.cloud.google.com/
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# GitHub OAuth
AUTH_GITHUB_ID=your-github-client-id
AUTH_GITHUB_SECRET=your-github-client-secret

# ----------------------------
# AI (Gemini)
# ----------------------------
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-pro

# ----------------------------
# Stripe
# ----------------------------
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-publishable-key

# Stripe Price IDs (create in Stripe Dashboard)
STRIPE_PRICE_MONTHLY=price_monthly_id
STRIPE_PRICE_SIX_MONTH=price_6month_id
STRIPE_PRICE_YEARLY=price_yearly_id
STRIPE_PRICE_LIFETIME=price_lifetime_id

# Stripe Coupons (create in Stripe Dashboard)
# Auto-applied for MONTHLY plan: 25% off, repeating, duration_in_months: 3
STRIPE_COUPON_MONTHLY_3MO_25OFF=coupon_id_for_25off_3months

# ----------------------------
# Cloudflare R2 (file storage)
# Alternative: Vercel Blob, AWS S3, Supabase Storage
# ----------------------------
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=resumeevy-files
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ----------------------------
# Email - Resend (recommended) → https://resend.com
# Free tier: 3,000 emails/month
# ----------------------------
EMAIL_SERVER_HOST=smtp.resend.com
EMAIL_SERVER_PORT=465
EMAIL_SERVER_USER=resend
EMAIL_SERVER_PASSWORD=re_your-resend-api-key
EMAIL_FROM=ResumeEvy <noreply@yourdomain.com>

# ----------------------------
# Admin
# ----------------------------
ADMIN_EMAIL=admin@yourdomain.com
